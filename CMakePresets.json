{
    "version": 3,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 29,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "default",
            "displayName": "Default Ninja Debug",
            "description": "Configure the TeachingEmbC workspace for VS Code CMake Tools.",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "description": "Build all targets in build/."
        }
    ],
    "testPresets": [
        {
            "name": "default",
            "configurePreset": "default",
            "description": "Run all discovered tests with output on failure.",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}